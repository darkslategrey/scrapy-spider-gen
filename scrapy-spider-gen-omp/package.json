{
	"name": "scrapy-spider-gen-omp",
	"version": "0.2.2-omp.1",
	"description": "Pi/omp extension — generates Scrapy spiders from web pages (oh-my-pi variant)",
	"keywords": [
		"pi-package",
		"pi-extension",
		"oh-my-pi",
		"omp",
		"scrapy",
		"spider",
		"html-cleaning"
	],
	"type": "module",
	"main": "src/index.ts",
	"files": [
		"src/**/*.ts",
		"!src/**/*.test.ts",
		"README.md",
		"LICENSE"
	],
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"license": "MIT",
	"scripts": {
		"build": "tsc",
		"check": "biome check .",
		"ci": "npm run check && npm run build && npm test",
		"format": "biome format --write .",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"peerDependencies": {
		"@oh-my-pi/pi-coding-agent": "*"
	},
	"dependencies": {
		"node-html-parser": "^6.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@oh-my-pi/pi-coding-agent": "16.0.2",
		"@types/node": "^24.0.0",
		"typescript": "^5.6.0",
		"vitest": "^2.1.0"
	}
}
