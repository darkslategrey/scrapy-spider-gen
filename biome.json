{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"root": true,
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended"
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"files": {
		"includes": [
			"**",
			"!!**/.pi",
			"!!**/.claude",
			"!!tmp",
			"!!scrapy-spider-gen-omp"
		],
		"ignoreUnknown": false
	},
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	}
}
